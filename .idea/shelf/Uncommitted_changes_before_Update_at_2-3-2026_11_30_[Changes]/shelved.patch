+from cropHarvesting import CROP_VALUES, inventory
+
+def sell_from_inventory(crop_name, money, inventory, fermented_inventory, values, bonus):
+    if fermented_inventory.get(crop_name, 0) > 0:
+        fermented_inventory[crop_name] -= 1
+        money += int(values[crop_name] * bonus)
+        return money
+
+    if inventory.get(crop_name, 0) > 0:
+        inventory[crop_name] -= 1
+        money += values[crop_name]
+    return money
+
